{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "sourceMap": false,
    "experimentalDecorators": true,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "declaration": true,
    "module": "esnext",
    "target": "esnext",
    "lib": ["DOM", "esnext"],
    "esModuleInterop": true,
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist/"],
  "include": ["src/**/*", "src/math/sum.spec.ts"]
}
